# ── Appwrite (backend) ─────────────────────────────────────────────
# Create a free project at https://cloud.appwrite.io
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
NEXT_PUBLIC_APPWRITE_DATABASE_ID=your_database_id

# Collection IDs (create these in Appwrite console)
NEXT_PUBLIC_APPWRITE_SERVICES_ID=services
NEXT_PUBLIC_APPWRITE_HAIRSTYLES_ID=hairstyles
NEXT_PUBLIC_APPWRITE_TESTIMONIALS_ID=testimonials
NEXT_PUBLIC_APPWRITE_APPOINTMENTS_ID=appointments
NEXT_PUBLIC_APPWRITE_FAQ_ID=faq

# Server-side API key (Admin → API Keys in Appwrite console)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_server_api_key

# ── AI Chat ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Email (booking confirmations) ──────────────────────────────────
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=bookings@yourdomain.com

# ── Voice AI ───────────────────────────────────────────────────────
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
